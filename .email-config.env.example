# Email Configuration (do NOT commit credentials!)
# Copy to .email-config.env and fill in values

# IMAP Account
HIMALAYA_EMAIL=your@email.com
HIMALAYA_PASSWORD=your-password-or-app-password
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USE_SSL=true

# SMTP Sender (outgoing)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=noreply@company.com
SMTP_USER=noreply@company.com
SMTP_PASSWORD=your-app-password

# Test recipients
HIMALAYA_TEST_TO=you@example.com
