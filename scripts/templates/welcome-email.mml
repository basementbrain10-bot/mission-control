// Welcome email template for new account verification
var subject = "Welcome! Please verify your account";
var from = "noreply@company.com";
to: ["{{user.email}}"]
body: |
  Hi {{user.name}}!,
  
  Welcome to our platform! To complete your registration, please verify your email address by clicking the link below:
  
  {{verification_link}}
  
  If you didn't create this account, please ignore this email.

  Best regards,
  The Team

