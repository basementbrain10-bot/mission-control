# Email Configuration for Himailaya Integration
# Copy from .email-config.env.example and fill in your credentials
#
# IMPORTANT: Never commit this file with real credentials!
# Use 1Password or similar secret manager for production.

# IMAP Account
HIMALAYA_EMAIL=
your@email.com
HIMALAYA_PASSWORD=your-app-password-here
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USE_SSL=true

# SMTP Sender (outgoing)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=noreply@company.com
SMTP_USER=noreply@company.com  
SMTP_PASSWORD=
YOUR-APP-PASSWORD-HERE

# Test recipients
HIMALAYA_TEST_TO=you@example.com
